# ---------------------------------------------------------
# Weather tool providers — configurable like the LLM.
# Switch endpoints (or go fully offline) via env, no code change.
# ---------------------------------------------------------

# --- geocoding ---
GEOCODER_PROVIDER=maps_co              # maps_co | static
GEOCODER_BASE_URL=https://geocode.maps.co/search   # point at an internal Nominatim mirror to repoint
GEOCODING_API_KEY=                     # free key at https://geocode.maps.co/ (inject at deploy)
GEOCODER_VERIFY_SSL=true
# offline / air-gap:
# GEOCODER_PROVIDER=static
# GEOCODER_STATIC={"pittsburgh, pa": [40.44, -79.99]}
# GEOCODER_STATIC_DEFAULT=40.44,-79.99

# --- forecast ---
FORECAST_PROVIDER=weather_gov          # weather_gov | static
FORECAST_BASE_URL=https://api.weather.gov          # point at a mirror to repoint
FORECAST_USER_AGENT=(squidfall, contact@example.com)
FORECAST_VERIFY_SSL=true
# offline / air-gap:
# FORECAST_PROVIDER=static
# FORECAST_STATIC_TEXT=Forecast service offline.

# --- shared ---
WEATHER_HTTP_TIMEOUT=30
