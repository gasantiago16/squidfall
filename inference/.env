# ---------------------------------------------------------
# LLM provider — select with LLM_PROVIDER (ollama | openai | azure_openai).
# Switching providers is config-only; the agent code never changes.
# Secrets (API keys / client secret) should be injected at deploy, not committed.
# ---------------------------------------------------------
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5
LLM_TEMPERATURE=0

# --- ollama (local dev default) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_NUM_CTX=8192

# --- openai-compatible gateway (vLLM / LiteLLM / internal proxy) ---
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://your-gateway/v1
# OPENAI_API_KEY=                       # inject at deploy; never commit

# --- azure openai (e.g. an Army Gov deployment) ---
# LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.us/
# AZURE_OPENAI_DEPLOYMENT=squidfall
# AZURE_OPENAI_API_VERSION=2024-02-01
#   auth — EITHER an API key:
# AZURE_OPENAI_API_KEY=                 # inject at deploy; never commit
#   OR Entra ID service principal (Gov cloud):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=                  # inject at deploy; never commit
# AZURE_AUTHORITY_HOST=https://login.microsoftonline.us
# AZURE_TOKEN_SCOPE=https://cognitiveservices.azure.us/.default

# --- Tools (MCP server) ---
TOOLS_ENDPOINT=http://squidfall-tools:8002/mcp
