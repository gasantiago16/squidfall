# --- LLM: local Ollama (default) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5
OLLAMA_NUM_CTX=8192

# --- Tools (MCP server) ---
TOOLS_ENDPOINT=http://squidfall-tools:8002/mcp

# --- Azure OpenAI (disabled toggle; set USE_AZURE=true to use instead) ---
USE_AZURE=false
