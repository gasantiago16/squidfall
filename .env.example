# Optional build/deploy config for docker compose (interpolated into
# compose.yml / compose.prod.yml). Copy to .env and fill for an air-gapped or
# mirrored environment. Unset/empty defaults = public internet (current behavior).

# Base image source, PREPENDED to every FROM (note the trailing slash):
#   e.g. mirror.internal/        ->  mirror.internal/python:3.12-slim
REGISTRY_PREFIX=

# Python package index (PyPI mirror) used during image builds:
#   e.g. https://nexus.internal/repository/pypi/simple
PIP_INDEX_URL=
PIP_TRUSTED_HOST=

# npm registry mirror used during the frontend build:
#   e.g. https://nexus.internal/repository/npm/
NPM_REGISTRY=

# Alpine apk mirror HOST (replaces dl-cdn.alpinelinux.org): e.g. apk.internal
APK_MIRROR=

# CD: image prefix for the prod-like deploy. Defaults to the local registry;
# GitLab CI overrides this with $CI_REGISTRY_IMAGE automatically.
PROD_IMAGE_PREFIX=localhost:5000/squidfall
